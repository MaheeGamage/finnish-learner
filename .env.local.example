# Copy to .env.local and replace placeholder values.

# --- Google OAuth (required for auth + Sheets) ---
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_URL=http://localhost:3000 #App URL (required — must match the URL you open in the browser)
AUTH_SECRET=generate-with-openssl-rand-base64-32 # NextAuth secret (required — any random string)

# Optional: set to false/0/no/off to disable saving new vocabulary rows.
NEXT_PUBLIC_VOCAB_SAVING_ENABLED=true
